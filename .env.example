# ConnectoFarmo Frontend - Environment Variables Template
# Copy this file to .env.local and update the values for your environment

# ============================================
# API Configuration
# ============================================

# Backend API Base URL
# Change this to match your backend server location
VITE_API_URL=http://localhost:8080

# API Request Timeout (in milliseconds)
# Default: 30 seconds (30000 ms)
# Increase this if requests are timing out
VITE_API_TIMEOUT=30000

# ============================================
# Environment
# ============================================

# Current environment (development, staging, production)
VITE_ENV=development

# ============================================
# Feature Flags
# ============================================

# Enable/disable analytics tracking
VITE_ENABLE_ANALYTICS=true

# ============================================
# Logging (for development)
# ============================================

# Debug mode - set to 'true' for verbose logging
VITE_DEBUG=false
